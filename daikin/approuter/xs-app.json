{
  "welcomeFile": "/index.html",
  "authenticationMethod": "route",
    "logout": {
    "logoutEndpoint": "/do/logout"
  },

  "routes": [
    {
      "source": "^/sap/(.*)$",
      "target": "/sap/$1",
      "destination": "SuppPro",
      "csrfProtection": false
    },
    {
      "source": "^/user-api(.*)",
      "target": "$1",
      "service": "sap-approuter-userapi",
      "authenticationType": "xsuaa"
      
    },
    {
      "source": "^/assets/(.*)$",
      "localDir": "resources",
      "authenticationType": "none"
    },
    {
      "source": "^/(.*\\.(png|svg|ico|jpg|jpeg|gif|css|js|woff|woff2|ttf|json|map))$",
      "localDir": "resources",
      "authenticationType": "none"
    },
    {
      "source": "^/.*$",
      "localDir": "resources",
      "target": "index.html",
      "authenticationType": "xsuaa"
    }
  ]
}