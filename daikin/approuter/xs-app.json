{
  "welcomeFile": "/index.html",
  "authenticationMethod": "route",
  "logout": {
    "logoutEndpoint": "/do/logout",
    "logoutPage": "/"
  },
  "routes": [
    {
      "source": "^/sap/(.*)$",
      "target": "/sap/$1",
      "destination": "FIEM_dev",
      "csrfProtection": false
    },
    {
      "source": "^/user-api(.*)",
      "target": "$1",
      "service": "sap-approuter-userapi",
      "authenticationType": "xsuaa"
    },
    {
      "source": "^/(.*\\.(png|svg|ico|jpg|jpeg|gif|pdf|css|js|woff|woff2|ttf|json|map))$",
      "target": "/fiemui-1.0.0/$1",
      "service": "html5-apps-repo-rt",
      "authenticationType": "none"
    },
    {
      "source": "^(?!/sap/|/user-api).*$",
      "target": "/fiemui-1.0.0/index.html",
      "service": "html5-apps-repo-rt",
      "authenticationType": "xsuaa"
    }
  ]
}